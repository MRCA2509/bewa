{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BEWA Desktop",
  "version": "2.0.0",
  "identifier": "com.bewa.podserver",
  "build": {
    "frontendDist": "../desktop",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BEWA POD Server Control",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
