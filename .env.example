# BEWA Logistics Environment Variables (VPS / Production Template)
# Security Configurations
BEWA_API_KEY=YOUR_SECURE_API_KEY_HERE
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_HERE

# Database Configurations
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_production_db_user
MYSQL_PASSWORD=your_production_db_password
MYSQL_DATABASE=bewa_logistics

