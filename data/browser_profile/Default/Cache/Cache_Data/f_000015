-item {\n        width: 60%;\n        margin: auto;\n        margin-top: 20px;\n        .el-form-item__label {\n          @include bg-forge-color('inputLabel');\n          font-size: 16px !important;\n          font-weight: bolder;\n        }\n\n        ::-webkit-input-placeholder {\n          @include bg-forge-color('tabFont');\n          font-size: 14px;\n        }\n\n        ::-moz-placeholder {\n          @include bg-forge-color('tabFont');\n          font-size: 14px;\n        }\n\n        :-ms-input-placeholder {\n          @include bg-forge-color('tabFont');\n          font-size: 14px;\n        }\n\n        .el-form-item__error {\n          padding-top: 10px;\n          color: $-color-danger;\n        }\n\n        .el-input__inner {\n          border-top-style: none;\n          border-right-style: none;\n          border-left-style: none;\n          border-radius: 0px;\n          background: none;\n          padding: 0;\n          font-size: 14px;\n          @include bg-forge-color('inputText');\n          @include bg-forge-color('inputBorder');\n        }\n      }\n\n      .is-error {\n        .el-input__inner {\n          border-color: $-color-danger !important;\n        }\n      }\n\n      .el-input__suffix {\n        right: 0;\n\n        .el-icon-circle-close {\n          color: $-color-danger;\n        }\n\n        .icon-eyes {\n          cursor: pointer;\n          font-size: 20px;\n        }\n      }\n    }\n  }\n\n  input:-webkit-autofill,\n  textarea:-webkit-autofill,\n  select:-webkit-autofill {\n    -webkit-box-shadow: 0 0 0px 1000px white inset !important;\n    background-color: rgb(0, 0, 0) !important;\n    background-image: none !important;\n    color: rgb(0, 0, 0) !important;\n    -webkit-tap-highlight-color: rgba(0, 0, 0, 0) !important;\n  }\n\n  .el-header {\n    display: flex;\n    position: absolute;\n    top: 0;\n    z-index: 1000;\n    padding: 0;\n    left: 0;\n    right: 0;\n    @include bg-forge-color('topBg');\n\n    .logo-box {\n     