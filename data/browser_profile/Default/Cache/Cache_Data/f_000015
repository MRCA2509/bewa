t-fill-color: #666 !important;\n    box-shadow: 0 0 0px 1000px transparent inset !important;\n    // background-color: transparent;\n    background-image: none;\n    opacity: 0.8;\n    transition: background-color 50000s ease-in-out 0s;\n  }\n\n  input {\n    background-color: transparent;\n  }\n}\n\n.loginDialog {\n  .el-dialog__header {\n    // display: none;\n    border-color: transparent;\n  }\n\n  .el-dialog__body {\n    display: flex;\n  }\n\n  .icon-type {\n    margin-right: 10px;\n  }\n\n  .iconjingshi {\n    color: $-color-warning;\n  }\n\n  .pull-left {\n    float: none;\n  }\n}\n\n@media screen and (min-width: 1441px) {\n  .login {\n    height: 100%;\n    width: 100%;\n    background: rgba(29, 12, 12, 0.5);\n    // @include base-bg-login();\n    background: url('../assets/images/login-bg-03.jpg');\n    background-repeat: no-repeat;\n    background-size: cover;\n\n    .l-main {\n      width: 100%;\n      height: 100%;\n      overflow: hidden;\n      position: relative;\n      position: absolute;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n\n      .lm-box {\n        width: $max-w;\n        // height: $max-h;\n        padding: 0 100px;\n        box-sizing: border-box;\n        background: rgba(255, 255, 255, 0.8);\n        box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.2);\n        border-radius: $lg-bt-radius;\n\n        .lmb-logo {\n          width: 100%;\n          text-align: center;\n          padding: 20px 0 30px 0;\n          margin-top: 80px;\n\n          .logo-image {\n            width: 176px;\n            height: 26px;\n            margin: 0 auto;\n          }\n        }\n\n        .login-content {\n          display: inline-block;\n          width: 100%;\n          height: auto;\n          padding-top: 32px;\n          position: relative;\n\n          .login-form {\n            .login-input {\n              margin-bottom: 0;\n              padding-left: 0px;\n              height: 48px;\n              border-bottom: 1px solid #c4c8cc;\n              box-sizing: border-box;\n\n              .toggleIcon {\n                position: absolute;\n                top: 10px;\n                right: 0;\n\n                .iconfont {\n                  color: $bg-color;\n                  cursor: pointer;\n                  font-size: 20px;\n                  margin: 0;\n                  // font-weight: bolder;\n                }\n              }\n\n              input:focus {\n                outline: none;\n              }\n\n              &.user {\n                .svg-icon {\n                  position: absolute;\n                  height: 20px;\n                  width: 20px;\n                  left: 0;\n                  top: 14px;\n                }\n\n                // .el-form-item__content {\n                //   &::before {\n                //     content: '\\e675';\n                //     font-size: 20px;\n                //   }\n                // }\n              }\n\n              &.pwd {\n                margin: 32px 0 0 0;\n\n                .svg-icon {\n                  position: absolute;\n                  height: 20px;\n                  width: 20px;\n                  left: 0;\n                  top: 14px;\n                }\n\n                // .el-form-item__content {\n                //   &::before {\n                //     content: '\\e678';\n                //     font-size: 20px;\n                //   }\n                // }\n              }\n\n              &.captchaCode {\n                margin: 32px 0 0 0;\n                position: relative;\n\n                // .el-form-item__content {\n                //   &::before {\n                //     content: '\\e7b6';\n                //     font-size: $default-size;\n                //   }\n                // }\n                .svg-icon {\n                  position: absolute;\n                  height: 20px;\n                  width: 20px;\n                  left: 0;\n                  top: 15px;\n                }\n\n                .captchaCodeBox {\n                  position: absolute;\n                  width: 148px;\n                  height: 42px;\n                  right: 0px;\n                  top: 5px;\n                  cursor: pointer;\n                }\n              }\n\n              &.active {\n\n                // .el-form-item__content::before {\n                //   color: $bg-color;\n                // }\n                .svg-icon {\n                  fill: $bg-color;\n                }\n\n                .el-input__inner {\n                  color: $bg-color;\n                  overflow: hidden;\n                }\n              }\n\n              .el-input__inner {\n                border-radius: 0;\n                border-left: 0;\n                border-right: 0;\n                border-top: 0;\n                border-bottom: none;\n                padding-left: 0;\n                background-color: transparent;\n                font-size: $default-size;\n                // height: $sm-input-h;\n                line-height: $sm-input-h;\n                padding: $sm-input-h / 2 0;\n                background-clip: content-box;\n                color: #666;\n              }\n\n              .el-form-item__error {\n                // white-space: nowrap;\n                margin-top: 10px;\n                padding: 0;\n                font-size: 12px;\n                color: $-color-danger;\n              }\n\n              .el-input__prefix {\n                .el-input__icon {\n                  &:before {\n                    color: #999999;\n                    font-size: 50px;\n                  }\n\n                  &:after {\n                    color: #999999;\n                    font-size: 50px;\n                  }\n                }\n              }\n\n              .el-input__suffix {\n                .el-input__icon {\n                  &:before {\n                    display: none;\n                  }\n                }\n              }\n            }\n\n            .el-form-item__content {\n              padding-left: $lg-lf-input;\n              padding-right: 20px;\n\n              &::before {\n                font-family: 'iconfont' !important;\n                font-style: normal;\n                font-weight: normal;\n                font-variant: normal;\n                text-transform: none;\n                line-height: 1;\n                vertical-align: baseline;\n                display: inline-block;\n                -webkit-font-smoothing: antialiased;\n                -moz-osx-font-smoothing: grayscale;\n                position: absolute;\n                left: $lg-icon-lf;\n                top: 17px;\n                font-size: 14px;\n                color: #888;\n              }\n            }\n          }\n\n          .is-error {\n            border-bottom: 1px solid $-color-danger !important;\n          }\n\n          .opt-pwd {\n            overflow: hidden;\n            text-align: left;\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            margin-top: 48px;\n\n            .remember-pwd {\n              cursor: pointer;\n              display: flex;\n              align-items: center;\n              justify-content: center;\n\n              .rp-check {\n                height: $default-size;\n                width: $default-size;\n                background-size: 100%;\n                background-image: url('../assets/images/login/check-un.png');\n              }\n\n              .rp-check-bg {\n                background-image: url('../assets/images/login/check-select-red.png');\n              }\n\n              .rp-text {\n                font-size: 14px;\n                color: #61666d;\n                padding-left: 6px;\n              }\n            }\n\n            .forget-pwd {\n              float: right;\n              cursor: pointer;\n              text-decoration: none;\n           