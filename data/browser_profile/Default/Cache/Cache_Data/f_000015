r;\n  align-items: center;\n  background-repeat: no-repeat;\n  @include bg-forge-image();\n\n  .headerInfo {\n    display: flex;\n    position: absolute;\n    top: 0;\n    z-index: 1000;\n    padding: 0;\n    left: 0;\n    right: 0;\n    height: 48px !important;\n    @include bg-forge-color('topBg');\n\n    .logo-box {\n      width: $asideWidth;\n      height: $topHeight;\n      display: flex;\n      transition: width 0.1s ease-out;\n      cursor: pointer;\n      align-items: center;\n      justify-content: center;\n      @include nav-color('textactive');\n\n      i {\n        font-size: 23px;\n      }\n    }\n\n    .header-right {\n      height: $topHeight;\n      text-align: center;\n      text-indent: -240px;\n      line-height: $topHeight;\n      // color: #fff;\n      flex: 1;\n      justify-content: center;\n      padding: 0 20px;\n      @include nav-color('clr');\n    }\n  }\n\n  .content {\n    width: 790px;\n    height: 600px;\n    @include bg-forge-color('content');\n    border-radius: 10px;\n    text-align: center;\n\n    .title {\n      h3 {\n        height: 86px;\n        line-height: 86px;\n        margin: 0;\n        font-size: 18px;\n        @include bg-forge-color('stepsBorder');\n        @include base-color-set('main');\n      }\n\n      p {\n        font-size: 16px;\n        line-height: 28px;\n        text-align: left;\n        // color: #333;\n        @include text-color('subtitle');\n        padding: 56px 40px;\n      }\n    }\n\n    .el-form {\n      box-sizing: border-box;\n      padding: 0 40px;\n    }\n\n    .form-item {\n      @include bg-forge-color('inputLabel');\n      font-size: 16px !important;\n      font-weight: 500;\n      text-align: left;\n      margin-bottom: 50px;\n\n      &::before {\n        color: $-color-brand;\n        font-weight: bolder;\n      }\n\n      .el-form-item__label {\n        @include bg-forge-color('inputLabel');\n        font-size: 16px !important;\n        font-weight: 500;\n        font-weight: bolder;\n\n        &::before {\n          color: $-color-brand;\n          font-weight: bolder;\n        }\n      }\n\n      ::v-deep .el-form-item__label {\n        @include bg-forge-color('inputLabel');\n        font-size: 16px !important;\n        font-weight: bolder;\n        float: none; // 取消label左浮动\n        word-break: break-word; // 支持单词截断换行\n      }\n\n      ::v-deep .el-form-item__content {\n        margin-left: 0 !important;\n      }\n\n      .el-form-item__error {\n        padding-top: 10px;\n        font-weight: 500;\n        color: $-color-danger;\n      }\n\n      .el-input__inner {\n        border-top-style: none;\n        border-right-style: none;\n        border-left-style: none;\n        border-radius: 0px;\n        background: none;\n        padding: 0;\n        font-size: 14px;\n        @include bg-forge-color('inputText');\n        @include bg-forge-color('inputBorder');\n      }\n\n      .el-input__suffix {\n        right: 0;\n\n        .el-icon-circle-close {\n          color: $-color-danger;\n        }\n\n        .icon-eyes {\n          cursor: pointer;\n          font-size: 20px;\n        }\n      }\n\n      .submitInfo {\n        height: 38px;\n        border-radius: 19px;\n        background: $-color-brand;\n        font-size: 16px;\n        border: 0;\n        width: 100%;\n        border-radius: 38px !important;\n      }\n    }\n\n    .phoneInput {\n      position: relative;\n\n      .resendCode {\n        position: absolute;\n        right: 0;\n        top: 30px;\n        background: #fff;\n        cursor: pointer;\n        z-index: 2;\n        @include base-color('clr');\n        @include bg-color('light');\n\n        .normal-text {\n          @include bg-forge-color('tabFont');\n        }\n      }\n    }\n  }\n}\n","/***********************************************   new   ************************************************/\r\n\r\n/**\r\n * @title 字号\r\n */\r\n// 最小号\r\n$font-size-small-x: 10px;\r\n// 小号\r\n$font-size-small: 12px;\r\n// 中号\r\n$font-size-medium: 14px;\r\n// 中大号\r\n$font-size-medium-x: 16px;\r\n// 大号\r\n$font-size-large: 18px;\r\n// 超大号\r\n$font-size-large-x: 22px;\r\n// 其他字号-13\r\n$font-size-13: 13px;\r\n// 其他字号-20\r\n$font-size-20: 20px;\r\n\r\n\r\n//  表单\r\n// 固定宽度\r\n$item-col-width: 200px;\r\n//  左右边距\r\n$item-col-padding-rl: 10px;\r\n// 卡片内边距\r\n$card-padding: 20px;\r\n\r\n\r\n/* Color\r\n-------------------------- */\r\n/// 浅色主题\r\n$-color-theme-shalow: #FFFFFF !default;\r\n/// 黑色主题\r\n$-color-theme-dark: #2D2D2D !default;\r\n/// 品牌色\r\n$-color-brand: #E60012 !default;\r\n$-color-brand-my: #DE0B0B !default;\r\n\r\n/// 白色\r\n$-color-white: #FFFFFF !default;\r\n/// 黑色\r\n$-color-black: #000000 !default;\r\n\r\n/// 成功\r\n$-color-success: #22CE88 !default;\r\n/// 提示\r\n$-color-warning: #FAA111 !default;\r\n/// 警示\r\n$-color-danger: #FF1333 !default;\r\n/// 描述\r\n$-color-info: #909399 !default;\r\n\r\n\r\n/**\r\n * @title 常用透明度\r\n */\r\n$-percent-1: 10%;\r\n$-percent-2: 20%;\r\n$-percent-3: 30%;\r\n$-percent-4: 40%;\r\n\r\n/// 品牌色扩展\r\n$-color-brand-light-1: mix($-color-white, $-color-brand, $-percent-1) !default;\r\n$-color-brand-light-2: mix($-color-white, $-color-brand, $-percent-2) !default;\r\n$-color-brand-light-3: mix($-color-white, $-color-brand, $-percent-3) !default;\r\n$-color-brand-light-4: mix($-color-white, $-color-brand, $-percent-4) !default;\r\n\r\n$-color-brand-dark-1: mix($-color-black, $-color-brand, $-percent-1) !default;\r\n$-color-brand-dark-2: mix($-color-black, $-color-brand, $-percent-2) !default;\r\n$-color-brand-dark-3: mix($-color-black, $-color-brand, $-percent-3) !default;\r\n$-color-brand-dark-4: mix($-color-black, $-color-brand, $-percent-4) !default;\r\n\r\n$-color-theme-dark-1: mix($-color-white, $-color-theme-dark, $-percent-1) !default;\r\n\r\n/********** 文字颜色--深色主题 ******************/\r\n// 主标题文字\r\n$-color-text-dark-main: $-color-white !default;\r\n// 次标题文字\r\n$-color-text-dark-subtitle: $-color-white !default;\r\n// 常规文字\r\n$-color-text-dark-routine: #DEDEDE !default;\r\n// 次要文字\r\n$-color-text-dark-secondary: #A1A3A6 !default;\r\n// 提示文字\r\n$-color-text-dark-occupy: #B2B2B2 !default;\r\n// 禁用状态文字\r\n$-color-text-dark-disabled: #888888 !default;\r\n\r\n/********** 文字颜色--浅色主题 ******************/\r\n// 主标题文字\r\n$-color-text-shalow-main: #2B2D42!default;\r\n// 次标题文字\r\n$-color-text-shalow-subtitle: #4C4D57 !default;\r\n// 常规文字\r\n$-color-text-shalow-routine: #61666D !default;\r\n// 次要文字\r\n$-color-text-shalow-secondary: #9499A3 !default;\r\n// 提示文字\r\n$-color-text-shalow-occupy: #A1A3A6 !default;\r\n// 禁用状态文字\r\n$-color-text-shalow-disabled: #BBBBBB !default;\r\n\r\n/********** 边框颜色--深色主题 ******************/\r\n// 一级边框（按钮边框颜色）\r\n$-color-border-dark-base: #4B4B4B !default;\r\n// 二级边框（表单组件边框颜色）\r\n$-color-border-dark-light: #4B4B4B !default;\r\n// 三级边框（其他边框：表格边框颜色，卡片边框颜色）\r\n$-color-border-dark-lighter: #4B4B4B !default;\r\n\r\n/********** 边框颜色--浅色主题 ******************/\r\n// 一级边框（按钮边框颜色）\r\n$-color-border-shalow-base: #B0B3B6 !default;\r\n// 二级边框（表单组件边框颜色）\r\n$-color-border-shalow-light: #C4C8CC !default;\r\n// 三级边框（其他边框：表格边框颜色，卡片边框颜色）\r\n$-color-border-shalow-lighter: #DCDEE1 !default;\r\n// 背景为红色的边框\r\n$-color-border-shalow-bg: #EF8585 !default;\r\n// 其他边框颜色（不在规范内）\r\n$-color-border-shalow-1: #ebebeb !default;\r\n\r\n/********** 背景色--深色主题 ******************/\r\n// 文字展示背景色\r\n$-color-bg-dark-base: #1B1B1B !default;\r\n// 标题（卡片）背景色\r\n$-color-bg-dark-light: #2D2D2D !default;\r\n// 弹出框背景色（下拉选择，日期选择，确认框背景色）\r\n$-color-bg-dark-pop: #1F1F1F !default;\r\n// 弹出框激活背景色（下拉选择，日期选择，确认框选中时候的背景色）\r\n$-color-bg-dark-pop-active: #2A2A2A !default;\r\n// 表单标题背景（30%透明度）； 导航栏输入框背景底色； 其他通用组件选择激活背景底色\r\n$-color-bg-dark-title-active: #363636 !default; // 4B4B4B\r\n// $-color-bg-dark-title-active: rgb(75, 75, 75, .3) !default; // 4B4B4B\r\n// 输入框背景\r\n$-color-bg-dark-input: #4B4B4B !default;\r\n// 输入控件背景色-禁用\r\n$-color-bg-dark-input-disabled: #404040 !default;\r\n// 表格当前选中行的颜色\r\n$-color-bg-dark-current: #4B4B4B !default;\r\n// 报价模板卡片操作栏背景色\r\n$-color-bg-dark-quote: #363636 !default;\r\n// 首页的块的激活颜色\r\n$-color-bg-dark-index-block-active: #242424 !default;\r\n// 滚动条-滑动条颜色\r\n$-color-bg-dark-scrollbar-thumb: #A1A3A6 !default;\r\n// 滚动条-滑动条背景颜色\r\n$-color-bg-dark-scrollbar-bg: #1F1F1F !default;\r\n\r\n/********** 背景色--浅色主题 ******************/\r\n// 文字展示背景色\r\n$-color-bg-shalow-base: #EBEBEB !default;\r\n// 弹窗背景色\r\n$-color-bg-shalow-light: #FFFFFF !default;\r\n// 弹出框背景色（下拉选择，日期选择，确认框背景色）\r\n$-color-bg-shalow-pop: #FFFFFF !default;\r\n// 弹出框激活背景色（下拉选择，日期选择，确认框选中时候的背景色）\r\n$-color-bg-shalow-pop-active: #F2F2F2 !default;\r\n// 表单标题背景（30%透明度）； 导航栏输入框背景底色； 其他通用组件选择激活背景底色\r\n$-color-bg-shalow-title-active: #F2F2F2 !default;\r\n// 输入框背景\r\n$-color-bg-shalow-input: #F2F2F2 !default;\r\n// 输入控件背景色-禁用\r\n$-color-bg-shalow-input-disabled: #F4F4F4 !default;\r\n// 其他背景色（不在规范内）\r\n$-color-bg-shalow-light-1: #EBEBEB !default;\r\n// 当前选中行的颜色\r\n$-color-bg-shalow-current: #F2F2F2 !default;\r\n// 报价模板卡片操作栏背景色\r\n$-color-bg-shalow-quote: #F2F2F2 !default;\r\n// 首页的块的激活颜色\r\n$-color-bg-shalow-index-block-active: #F2F2F2 !default;\r\n// 滚动条-滑动条颜色\r\n$-color-bg-shadlow-scrollbar-thumb: #B2B2B2 !default;\r\n// 滚动条-滑动条背景颜色\r\n$-color-bg-shadlow-scrollbar-bg: #F2F2F2 !default;\r\n\r\n/********** 图标色--深色主题 ******************/\r\n// 品牌颜色图标\r\n$-color-icon-dark-brand: $-color-brand !default;\r\n// 侧边栏图标颜色\r\n$-color-icon-dark-nav: #C4C8CC !default;\r\n// 常规图标颜色\r\n$-color-icon-dark-routine: #B2B2B2 !default;\r\n// 禁用图标颜色\r\n$-color-icon-dark-disabled: #888888 !default;\r\n\r\n/********** 图标色--浅色主题 ******************/\r\n// 品牌颜色图标\r\n$-color-icon-shalow-brand: $-color-brand !default;\r\n// 侧边栏图标颜色\r\n$-color-icon-shalow-nav: #9499A3 !default;\r\n// 常规图标颜色\r\n$-color-icon-shalow-routine: #A1A3A6 !default;\r\n// 禁用图标颜色\r\n$-color-icon-shalow-disabled: #BBBBBB !default;\r\n\r\n// 阴影\r\n$-color-shadow-dark: rgba(209,213,223,0) !default;\r\n$-color-shadow-shalow:  rgba(209,213,223,0.5) !default;\r\n\r\n$-color-shadow-entity-dark: #4B4B4B !default;\r\n$-color-shadow-entity-shalow:  #E3E3E3 !default;\r\n$-color-shadow-entity-shalow-brand:  #EF8585 !default;\r\n\r\n/* Font\r\n------------*/\r\n$-font-path: 'fonts' !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-extra-large: 20px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-large: 18px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-medium: 16px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-base: 14px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-small: 13px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-extra-small: 12px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-extra-small-r: 10px !default;\r\n/// fontWeight|1|Font Weight|1\r\n$-font-weight-primary: 500 !default;\r\n/// fontWeight|1|Font Weight|1\r\n$-font-weight-secondary: 100 !default;\r\n/// fontLineHeight|1|Line Height|2\r\n$-font-line-height-primary: 24px !default;\r\n/// fontLineHeight|1|Line Height|2\r\n$-font-line-height-secondary: 16px !default;\r\n$-font-color-disabled-base: #bbb !default;\r\n\r\n/* z-index\r\n-------------------------- */\r\n$--index-normal: 1 !default;\r\n$--index-top: 1000 !default;\r\n$--index-popper: 2000 !default;\r\n\r\n/* 通用圆角 */\r\n$radius-base: 8px !default;\r\n\r\n/* Disable base\r\n-------------------------- */\r\n// 禁用-边框-深色-基础\r\n$-disabled-border-dark-base: $-color-border-dark-base !default;\r\n\r\n// 禁用-填充-深色-基础\r\n$-disabled-fill-dark-base: #5A5B5C !default;\r\n\r\n// 禁用-文字-浅色-基础\r\n$-disabled-text-shalow-base: $-color-text-dark-routine !default;\r\n\r\n// 禁用-边框-浅色-基础\r\n$-disabled-border-shalow-base: $-color-border-shalow-base !default;\r\n// 禁用-边框-浅色-品牌色\r\n$-disabled-border-shalow-brand: rgba($-color-brand, 0.1) !default;\r\n\r\n// 禁用-填充-浅色-基础\r\n$-disabled-fill-shalow-base: $-color-white !default;\r\n// 禁用-填充-浅色-轻\r\n$-disabled-fill-shalow-light: $-color-bg-shalow-light-1 !default;\r\n\r\n// 禁用-文字-浅色-基础\r\n$-disabled-text-shalow-base: $-color-text-shalow-routine !default;\r\n\r\n\r\n/* Active base\r\n-------------------------- */\r\n// 激活-边框-深色\r\n$-active-border-dark-base: $-color-border-dark-base !default;\r\n$-active-border-dark-brand: $-color-brand !default;\r\n// 激活-填充\r\n$-active-fill-dark-base: rgba($-color-black, 0.1) !default;\r\n$-active-fill-dark-light: rgba($-color-brand, 0.1) !default;\r\n$-active-fill-dark-brand: $-color-brand-dark-1 !default;\r\n// 激活-文字\r\n$-active-text-dark-base: $-color-text-dark-routine !default;\r\n// 激活-文字-品牌色-加深\r\n$-active-text-dark-brand: $-color-brand !default;\r\n\r\n// 激活-边框-浅色\r\n$-active-border-shalow-base: $-color-border-dark-base !default;\r\n$-active-border-shalow-brand: $-color-brand !default;\r\n\r\n// 激活-填充-浅色\r\n$-active-fill-shalow-base: rgba($-color-brand, 0.1) !default;\r\n$-active-fill-shalow-brand-deep: $-color-brand-dark-1 !default;\r\n$-active-fill-shalow-brand: #E83C3C !default;\r\n\r\n// 激活-文字-浅色\r\n$-active-text-shalow-base: $-color-text-shalow-routine !default;\r\n\r\n\r\n$-bg-color-hover: #F7F8FA !default;\r\n$-bg-color-hover-brand: #E83C3C !default;\r\n$-bg-color-hover-dark: #1F1F1F !default;\r\n/* Siderbar\r\n----------------*/\r\n$-sider-bg-dark-base: #2D2D2D !default;\r\n$-sider-bg-dark-row: #212020 !default;\r\n$-sider-text-dart: $-color-white !default;\r\n$-sider-text-dart-active: $-color-brand !default;\r\n$-sider-line-dark: $-color-bg-dark-base !default;\r\n\r\n$-sider-bg-shalow-base: $-color-white !default;\r\n$-sider-bg-shalow-brand: $-color-brand !default;\r\n$-sider-bg-shalow-row: $-color-brand !default;\r\n// $-sider-bg-shalow-row: #F3F4F6 !default;\r\n$-sider-bg-shalow-brand: #F2F2F2 !default;\r\n$-sider-bg-shalow-active: #F2F2F2 !default;\r\n$-sider-text-shalow: $-color-text-shalow-main !default;\r\n$-sider-text-shalow-active: $-color-brand !default;\r\n$-sider-text-red: $-color-text-shalow-main !default;\r\n$-sider-text-red-active: $-color-brand !default;\r\n$-sider-line-shadow: $-color-border-shalow-lighter !default;\r\n/* Nav\r\n----------------*/\r\n\r\n/** border-r