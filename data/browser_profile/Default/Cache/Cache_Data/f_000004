76px;\r\n\r\n/* flex */\r\n.s-flex {\r\n  display: flex;\r\n}\r\n.s-flex-ac {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n.s-flex-ac-jc {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.s-flex-ac-js {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n}\r\n.ml-8 {\r\n  margin-left: 8px;\r\n}\r\n\r\n/* 侧边栏 */\r\n.sidebar-wrap {\r\n  position: relative;\r\n  height: calc(100% - 50px);\r\n  width: 256px;\r\n  transition: all 0.2s;\r\n}\r\n\r\n/* 侧边栏 -- logo */\r\n.sidebar-logo {\r\n  height: 60px;\r\n  width: 250px;\r\n  transition: all 0.2s;\r\n  padding: 0 8px;\r\n  cursor: pointer;\r\n  .logo-img {\r\n    width: 100%;\r\n  }\r\n}\r\n\r\n/* 侧边栏 -- 菜单 */\r\n.sidebar-menu {\r\n  position: relative;\r\n  height: calc(100% - 180px);\r\n  padding: 0 8px;\r\n  box-sizing: border-box;\r\n}\r\n.menu-list {\r\n  height: 100%;\r\n}\r\n.menu-item {\r\n  padding: 10px;\r\n  cursor: pointer;\r\n  border-radius: 6px;\r\n  font-size: 14px;\r\n  @include text-color('my');\r\n  &.active,\r\n  &:hover {\r\n    font-weight: 700;\r\n    @include text-color('brand');\r\n    box-shadow: 0px 3px 4px 0px rgba(38, 46, 61, 0.04);\r\n    .sys-svg-icon,\r\n    .sys-icon {\r\n      @include text-color('brand');\r\n    }\r\n  }\r\n  &:nth-child(n + 1) {\r\n    margin-bottom: 4px;\r\n  }\r\n  &.level-1 {\r\n    width: $sidebar-menu-1-w;\r\n  }\r\n  &.level-2 {\r\n    width: $sidebar-menu-2-w;\r\n  }\r\n  &.level-3 {\r\n    width: $sidebar-menu-3-w;\r\n  }\r\n  .down-link {\r\n    color: #fff;\r\n    font-size: 12px\r\n  }\r\n}\r\n.menu-item-text {\r\n  @include text-color('main');\r\n}\r\n.sys-icon {\r\n  flex: none;\r\n  &.mi-star {\r\n    color: $star-color-active;\r\n  }\r\n}\r\n.sys-svg-icon {\r\n  flex: none;\r\n  width: 15px;\r\n  height: 15px;\r\n  fill: currentColor;\r\n  transition: all 0.2s;\r\n}\r\n.my-collect {\r\n  border-bottom: 1px solid;\r\n  @include border-color('my-main', 'bottom');\r\n}\r\n.sidebar-menu-main {\r\n  height: calc(100% - 50px);\r\n  position: relative;\r\n}\r\n.sidebar-scroll {\r\n  overflow: auto;\r\n  &::-webkit-scrollbar {\r\n    width: 5px;\r\n  }\r\n}\r\n\r\n/* 侧边栏 -- 底部常用 */\r\n.sidebar-guide {\r\n  padding: 0 8px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n/* 侧边栏折叠 */\r\n.sidebar-collapse {\r\n  transition: all 0.2s;\r\n  &.sidebar-wrap {\r\n    width: 64px;\r\n  }\r\n  .sys-icon {\r\n    font-size: 20px;\r\n  }\r\n  .sys-svg-icon {\r\n    width: 20px;\r\n    height: 20px;\r\n  }\r\n  .menu-item {\r\n    justify-content: center;\r\n  }\r\n  .sidebar-logo {\r\n    width: 64px;\r\n  }\r\n}\r\n\r\n// 红色主题\r\n[data-theme='green-theme'],\r\n[data-theme='default-theme'] {\r\n  .menu-item {\r\n    &.active,\r\n    &:hover {\r\n      background: #fff;\r\n      .menu-item-text {\r\n        color: $-color-brand;\r\n      }\r\n    }\r\n  }\r\n  .collect-menu {\r\n    background: #fff;\r\n    .menu-item {\r\n      &.active,\r\n      &:hover {\r\n        background: #f7f8fa;\r\n        .menu-item-text {\r\n          color: $-color-brand;\r\n        }\r\n      }\r\n  }\r\n  }\r\n}\r\n\r\n// 黑色主题\r\n[data-theme='black-theme'] {\r\n  .menu-item {\r\n    &.active,\r\n    &:hover {\r\n      background: rgba(222, 11, 11, 0.15);\r\n      .menu-item-text {\r\n        color: $-color-brand;\r\n      }\r\n    }\r\n  }\r\n  .collect-menu {\r\n    background: $black-bg-color;\r\n  }\r\n}\r\n","/*\r\n * @Description: 主题颜色宏定义\r\n * @Author: xujian\r\n * @Date: 2020-07-26 14:50:01\r\n */\r\n\r\n// 默认主题\r\n$default-theme: (\r\n  \r\n/********** 文字颜色--白色主题 ******************/\r\n  // 品牌色文字颜色\r\n  text-color-brand: $-color-brand,\r\n  text-color-brand-my: $-color-brand-my,\r\n  // 主标题文字颜色 （主题色）\r\n  text-color-main: $-color-text-shalow-main,\r\n  // 次标题文字\r\n  text-color-subtitle: $-color-text-shalow-subtitle,\r\n  // 常规文字\r\n  text-color-routine: $-color-text-shalow-routine,\r\n  // 次要文字\r\n  text-color-secondary: $-color-text-shalow-secondary,\r\n  // 提示文字\r\n  tex