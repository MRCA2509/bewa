x;\n      margin-right: 6px;\n      border-radius: 4px;\n      &:hover {\n        background: $-active-fill-dark-light !important;\n      }\n    }\n  }\n  .el-tabs {\n    width: calc(100% - 88px);\n    height: $tag-height;\n    .el-tabs__header {\n      height: $tag-height;\n      border-bottom: 1px solid;\n      @include border-color-important('my-main');\n      margin: 0;\n      .el-tabs__nav-wrap {\n        height: $tag-height;\n        .el-tabs__nav-prev {\n          width: 20px;\n          height: $tag-height;\n          line-height: $tag-height;\n          text-align: center;\n          // background-color: rgba(255, 255, 255, 0.6);\n          border-radius: 5px 0px 0px 0px;\n          @include bg-color('main');\n          border-bottom: 1px solid;\n          @include border-color('my-main', 'bottom');\n          .el-icon-arrow-left {\n            // color: #000000 !important;\n            @include text-color-important('routine');\n          }\n        }\n        .el-tabs__nav-next {\n          width: 20px;\n          height: $tag-height;\n          line-height: $tag-height;\n          text-align: center;\n          // background-color: rgba(255, 255, 255, 0.6);\n          border-radius: 0px 5px 0px 0px;\n          @include bg-color('main');\n          border-bottom: 1px solid;\n          @include border-color('my-main', 'bottom');\n          .el-icon-arrow-right {\n            @include text-color-important('routine');\n          }\n        }\n        .el-tabs__nav-scroll {\n          height: $tag-height;\n          width: 100%;\n          margin: auto;\n          .el-tabs__nav {\n            height: $tag-height;\n            border: none;\n            overflow: hidden;\n            border-top-left-radius: 4px;\n            border-top-right-radius: 4px;\n            .el-tabs__item.is-top {\n              height: $tag-height;\n              font-size: 12px;\n              line-height: $tag-height;\n              padding: 0px 16px;\n              border: 0px;\n              font-weight: 300;\n              text-align: center;\n              overflow: hidden;\n              -o-text-overflow: ellipsis;\n              text-overflow: ellipsis;\n              white-space: nowrap;\n              margin-right: 1px;\n              border-bottom: 1px solid;\n              @include border-color('my-main', 'bottom');\n              .el-icon-close {\n                position: absolute;\n                top: 9px;\n                right: 1px;\n                margin: 0px;\n              }\n            }\n            .is-active.is-top {\n              padding: 0px 28px 0px 16px;\n              border: 1px solid;\n              @include border-color('my-main', 'top');\n              @include border-color('my-main', 'left');\n              @include border-color('my-main', 'right');\n              border-bottom: 0px;\n              border-radius: 4px 4px 0px 0px;\n              font-weight: bold;\n              @include text-color('brand-my');\n              .el-icon-close {\n                right: 12px;\n              }\n            }\n            .el-tabs__item:first-child{\n              padding-right: 20px!important;\n            }\n          }\n        }\n      }\n      .is-scrollable {\n        .el-tabs__nav-scroll {\n          width: 99%;\n        }\n      }\n    }\n  }\n  .tags-view-item {\n    &:first-child {\n      .tag-item {\n        margin-left: 0;\n      }\n    }\n    display: inline-block;\n    position: relative;\n    cursor: pointer;\n    .tag-item {\n      display: block;\n      width: 125px;\n      height: $tag-height;\n      line-height: $tag-height;\n      color: #999999;\n      background: #eeeeee;\n      font-size: 14px;\n      margin-left: 6px;\n      border-radius: 5px 5px 0px 0px;\n      white-space: nowrap;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      // max-width: 200px;\n    }\n    &.active {\n      .tag-item {\n        background-color: #a5acc8;\n        color: #ffffff;\n        // color: $--