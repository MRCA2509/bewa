 none;\n    }\n    > i {\n      margin-right: 0px;\n      width: 52px;\n      display: inline-block;\n      text-align: center;\n    }\n    &:focus,\n    &:not(.is-disabled):hover {\n      color: $-color-brand;\n    }\n  }\n}\n\n.el-header {\n  display: flex;\n  justify-content: space-between;\n  position: relative;\n  top: 0;\n  z-index: 1000;\n  padding: 0;\n  left: 0;\n  right: 0;\n  @include nav-color('');\n  &::after {\n    content: ' ';\n    position: absolute;\n    width: 100%;\n    height: 1px;\n    bottom: -1px;\n    @include nav-color('bg-line');\n  }\n  .logo-box {\n    height: $topHeight;\n    text-align: left;\n    transition: width 0.1s ease-out;\n    cursor: pointer;\n    line-height: $topHeight;\n    background-repeat: no-repeat;\n    background-position: center;\n    @include nav-color('textactive');\n    i {\n      font-size: 23px;\n    }\n    .logo-img {\n      font-size: 24px;\n      transition: width 0.1s ease-out;\n      color: #fff;\n    }\n    .logo-image {\n      width: 204px;\n      height: 26px;\n      margin: 0 auto;\n      transition: all 0.3s ease-out;\n    }\n  }\n  .header-left {\n    box-sizing: border-box;\n    height: $topHeight;\n    flex: 1;\n    max-width: calc(100% - 520px);\n  }\n  .settingLeft{\n    max-width: calc(100% - 700px);\n  }\n  .header-right {\n    cursor: pointer;\n    line-height: 48px;\n    height: 100%;\n    max-width: 520px;\n    padding-right: 10px;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: row-reverse;\n    .el-badge {\n      display: block;\n    }\n    .el-badge__content.is-fixed {\n      top: 2px;\n      right: 8px;\n      &.is-dot {\n        @include nav-color('dot');\n      }\n    }\n    .top-icon-i {\n      margin-right: 4px;\n\n      .el-dropdown-link {\n        display: flex;\n        @include nav-color('clr');\n        .dropdowm-name {\n          display: flex;\n          flex-direction: column;\n          padding: 6px 0;\n          max-width: 120px;\n          margin-right: 10px;\n          font-weight: bold;\n          div {\n            line-height: 18px;\n            text-overflow: ellipsis;\n            white-space: nowrap;\n            overflow: hidden;\n            font-size: 12px;\n          }\n          .network-name {\n            font-size: 14px;\n          }\n        }\n        .icon {\n          font-size: 26px;\n          padding-top: 11px;\n          margin-right: 10px;\n          width: 26px;\n          height: 26px;\n        }\n        i {\n          line-height: 48px;\n          font-size: 14px;\n          @include nav-color('icon');\n        }\n      }\n    }\n    .top-round-btn {\n      margin-right: 10px;\n      outline: none;\n      display: inline-block;\n      width: $top-btn-width;\n      height: $top-btn-width;\n      border-radius: $top-btn-width;\n      line-height: $top-btn-width;\n      text-align: center;\n      font-size: 12px;\n      color: $-color-icon-shalow-nav;\n      @include nav-color('icon');\n      span {\n        font-size: 12px;\n      }\n      i {\n        font-size: 18px;\n      }\n    }\n    .iconsousuo1 {\n      margin: 0 5px;\n      font-size: 12px !important ;\n      @include nav-color('icon');\n    }\n  }\n}\n.paltformMenu {\n  width: 360px;\n  padding: 30px 15px 10px 15px;\n  .platform {\n    float: left;\n    width: 25%;\n    padding: 0 !important;\n    margin-bottom: 12px;\n    .icon-wrap {\n      width: 60px;\n      height: 60px;\n      text-align: center;\n      line-height: 60px;\n      margin: 0 auto;\n      background-color: #eef1f6;\n      border-radius: 4px;\n      &:hover,\n      &:focus {\n        @include base-color('bg');\n        & + .plat-name {\n          @include base-color('clr');\n        }\n        i {\n          color: #fff !important;\n        }\n      }\n      i {\n        font-size: 24px;\n        margin-right: 0;\n        @include base-color('clr');\n        &.iconyunshu {\n          font-size: 14px;\n        }\n        &.iconcaozuo {\n          font-size: 26px;\n        }\n      }\n    }\n    .plat-name {\n      text-align: center;\n      font-size: 12px;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      white-space: nowrap;\n      &:hover {\n        @include base-color('clr');\n      }\n    }\n  }\n  .el-dropdown-menu__item:focus,\n  .el-dropdown-menu__item:hover {\n    background-color: transparent;\n  }\n}\n.el-badge__content {\n  border: none;\n}\n.back-icon {\n  font-size: 12px;\n}\n","/***********************************************   new   ************************************************/\r\n\r\n/**\r\n * @title 字号\r\n */\r\n// 最小号\r\n$font-size-small-x: 10px;\r\n// 小号\r\n$font-size-small: 12px;\r\n// 中号\r\n$font-size-medium: 14px;\r\n// 中大号\r\n$font-size-medium-x: 16px;\r\n// 大号\r\n$font-size-large: 18px;\r\n// 超大号\r\n$font-size-large-x: 22px;\r\n// 其他字号-13\r\n$font-size-13: 13px;\r\n// 其他字号-20\r\n$font-size-20: 20px;\r\n\r\n\r\n//  表单\r\n// 固定宽度\r\n$item-col-width: 200px;\r\n//  左右边距\r\n$item-col-padding-rl: 10px;\r\n// 卡片内边距\r\n$card-padding: 20px;\r\n\r\n\r\n/* Color\r\n-------------------------- */\r\n/// 浅色主题\r\n$-color-theme-shalow: #FFFFFF !default;\r\n/// 黑色主题\r\n$-color-theme-dark: #2D2D2D !default;\r\n/// 品牌色\r\n$-color-brand: #E60012 !default;\r\n$-color-brand-my: #DE0B0B !default;\r\n\r\n/// 白色\r\n$-color-white: #FFFFFF !default;\r\n/// 黑色\r\n$-color-black: #000000 !default;\r\n\r\n/// 成功\r\n$-color-success: #22CE88 !default;\r\n/// 提示\r\n$-color-warning: #FAA111 !default;\r\n/// 警示\r\n$-color-danger: #FF1333 !default;\r\n/// 描述\r\n$-color-info: #909399 !default;\r\n\r\n\r\n/**\r\n * @title 常用透明度\r\n */\r\n$-percent-1: 10%;\r\n$-percent-2: 20%;\r\n$-percent-3: 30%;\r\n$-percent-4: 40%;\r\n\r\n/// 品牌色扩展\r\n$-color-brand-light-1: mix($-color-white, $-color-brand, $-percent-1) !default;\r\n$-color-brand-light-2: mix($-color-white, $-color-brand, $-percent-2) !default;\r\n$-color-brand-light-3: mix($-color-white, $-color-brand, $-percent-3) !default;\r\n$-color-brand-light-4: mix($-color-white, $-color-brand, $-percent-4) !default;\r\n\r\n$-color-brand-dark-1: mix($-color-black, $-color-brand, $-percent-1) !default;\r\n$-color-brand-dark-2: mix($-color-black, $-color-brand, $-percent-2) !default;\r\n$-color-brand-dark-3: mix($-color-black, $-color-brand, $-percent-3) !default;\r\n$-color-brand-dark-4: mix($-color-black, $-color-brand, $-percent-4) !default;\r\n\r\n$-color-theme-dark-1: mix($-color-white, $-color-theme-dark, $-percent-1) !default;\r\n\r\n/********** 文字颜色--深色主题 ******************/\r\n// 主标题文字\r\n$-color-text-dark-main: $-color-white !default;\r\n// 次标题文字\r\n$-color-text-dark-subtitle: $-color-white !default;\r\n// 常规文字\r\n$-color-text-dark-routine: #DEDEDE !default;\r\n// 次要文字\r\n$-color-text-dark-secondary: #A1A3A6 !default;\r\n// 提示文字\r\n$-color-text-dark-occupy: #B2B2B2 !default;\r\n// 禁用状态文字\r\n$-color-text-dark-disabled: #888888 !default;\r\n\r\n/********** 文字颜色--浅色主题 ******************/\r\n// 主标题文字\r\n$-color-text-shalow-main: #2B2D42!default;\r\n// 次标题文字\r\n$-color-text-shalow-subtitle: #4C4D57 !default;\r\n// 常规文字\r\n$-color-text-shalow-routine: #61666D !default;\r\n// 次要文字\r\n$-color-text-shalow-secondary: #9499A3 !default;\r\n// 提示文字\r\n$-color-text-shalow-occupy: #A1A3A6 !default;\r\n// 禁用状态文字\r\n$-color-text-shalow-disabled: #BBBBBB !default;\r\n\r\n/********** 边框颜色--深色主题 ******************/\r\n// 一级边框（按钮边框颜色）\r\n$-color-border-dark-base: #4B4B4B !default;\r\n// 二级边框（表单组件边框颜色）\r\n$-color-border-dark-light: #4B4B4B !default;\r\n// 三级边框（其他边框：表格边框颜色，卡片边框颜色）\r\n$-color-border-dark-lighter: #4B4B4B !default;\r\n\r\n/********** 边框颜色--浅色主题 ******************/\r\n// 一级边框（按钮边框颜色）\r\n$-color-border-shalow-base: #B0B3B6 !default;\r\n// 二级边框（表单组件边框颜色）\r\n$-color-border-shalow-light: #C4C8CC !default;\r\n// 三级边框（其他边框：表格边框颜色，卡片边框颜色）\r\n$-color-border-shalow-lighter: #DCDEE1 !default;\r\n// 背景为红色的边框\r\n$-color-border-shalow-bg: #EF8585 !default;\r\n// 其他边框颜色（不在规范内）\r\n$-color-border-shalow-1: #ebebeb !default;\r\n\r\n/********** 背景色--深色主题 