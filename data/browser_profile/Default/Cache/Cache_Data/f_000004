ult-theme,\r\n  green-theme: $green-theme,\r\n  // blue-theme: $blue-theme,\r\n  black-theme: $black-theme,\r\n);\r\n$asideWidth: $side-bar-first-width + $side-bar-second-width; // 侧边栏宽度\r\n$topHeight: 48px; //顶栏高度\r\n// $mini-sidebar:112px; //收缩后的菜单\r\n$mini-sidebar: $side-bar-first-width; //收缩后的菜单\r\n$submenu-height: 42px; // submenu 行高\r\n$menu-height: 42px; // 子菜单高度\r\n// 自定义滚动条\r\n@mixin scrollBarStyle() {\r\n  &::-webkit-scrollbar {\r\n    width: 7px;\r\n    height: 7px;\r\n  }\r\n  &::-webkit-scrollbar-thumb {\r\n    border-radius: 10px;\r\n    -webkit-box-shalow: inset 0 0 5px #9b9ba3;\r\n    background: rgba(152, 155, 163, 0.5);\r\n  }\r\n}\r\n\r\n@mixin theme-menu-indexCol($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == col {\r\n        border-color: map-get($theme, menu-border-col);\r\n        // color: map-get($map: $theme, $key: sub-first);\r\n      } @else if $type == hidecol {\r\n        color: map-get($theme, menu-hide-col);\r\n      } @else if $type == menu {\r\n        color: map-get($theme, menu-menu-col);\r\n      } @else if $type == file {\r\n        color: map-get($theme, menu-file-col);\r\n      }\r\n    }\r\n  }\r\n}\r\n// 主题色\r\n@mixin base-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == clr {\r\n        color: map-get($map: $theme, $key: color-main);\r\n      } @else if $type == bg {\r\n        background-color: map-get($map: $theme, $key: color-main);\r\n      } @else {\r\n        background-color: map-get($map: $theme, $key: color-main);\r\n        color: map-get($map: $theme, $key: color-main);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 主题色-new\r\n@mixin base-color-set($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == main {\r\n        color: map-get($map: $theme, $key: text-color-base);\r\n      } @else if $type == subtitle {\r\n        color: map-get($map: $theme, $key: text-color-subtitle);\r\n      } @else if $type == routine {\r\n        color: map-get($map: $theme, $key: text-color-routine) !important;\r\n      } @else if $type == secondary {\r\n        color: map-get($map: $theme, $key: text-color-secondary);\r\n      } @else if $type == occupy {\r\n        color: map-get($map: $theme, $key: text-color-occupy);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 获取主题边框\r\n@mixin base-border() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      border-color: map-get($map: $theme, $key: border-color);\r\n      //  阴影颜色无法单独替换，只能隐藏\r\n      box-shadow: none;\r\n    }\r\n  }\r\n}\r\n// 获取主题下边框\r\n@mixin base-bottom-border() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      border-bottom-color: map-get($map: $theme, $key: border-color);\r\n    }\r\n  }\r\n}\r\n\r\n// 主题色透明背景\r\n@mixin theme-hover() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background-color: map-get($map: $theme, $key: light-btn-bg);\r\n    }\r\n  }\r\n}\r\n\r\n// 主题色透明背景\r\n@mixin theme-hover-sub() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background-color: map-get($map: $theme, $key: light-btn-bg-hover);\r\n      // border-bottom: 1px solid map-get($map: $theme, $key: light-btn-text );\r\n      // border-top: 1px solid map-get($map: $theme, $key: light-btn-text );\r\n    }\r\n  }\r\n}\r\n\r\n// 主题border\r\n@mixin base-border-color() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      border: 1px solid map-get($map: $theme, $key: border-color);\r\n      //  阴影颜色无法单独替换，只能隐藏\r\n      box-shadow: none;\r\n    }\r\n  }\r\n}\r\n\r\n// 进入系统的loading\r\n@mixin base-app-loading() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background: map-get($map: $theme, $key: app-loading);\r\n    }\r\n  }\r\n}\r\n\r\n/********  New\r\n-----------------------*/\r\n// 侧边菜单栏\r\n@mixin sider-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == textbase {\r\n        color: map-get($map: $theme, $key: text-color-sider);\r\n      } @else if $type == textactive {\r\n        color: map-get($map: $theme, $key: text-color-sider--active);\r\n      } @else if $type == bg-active {\r\n        background-color: map-get($map: $theme, $key: bg-active-color);\r\n      } @else if $type == bg-hover {\r\n        background-color: map-get($map: $theme, $key: bg-sider-hover-color);\r\n      } @else if $type == bd-line {\r\n        border-right-color: map-get($map: $theme, $key: bg-sider-line-color);\r\n      } @else if $type == bd-line-arrow {\r\n        border-color: map-get($map: $theme, $key: bg-sider-line-color);\r\n      } @else if $type == text-2-active {\r\n        color: $-color-brand;\r\n      } @else if $type == logo {\r\n        background-image: map-get($map: $theme, $key: color-nav-logo);\r\n      } @else if $type == logo-cut {\r\n        background-image: map-get($map: $theme, $key: color-nav-logo--cut);\r\n      } @else if $type == bg {\r\n        background-color: map-get($map: $theme, $key: bg-color-sider);\r\n      } @else if $type == logobox-line {\r\n        background-color: map-get($map: $theme, $key: bg-sider-boxline-color);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: text-color-brand);\r\n        background-color: map-get($map: $theme, $key: bg-color-sider-row);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 侧边菜单栏\r\n@mixin sider-color-search() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      color: map-get($map: $theme, $key: menu-search-color);\r\n      background-color: map-get($map: $theme, $key: menu-search-bg);\r\n      border: map-get($map: $theme, $key: menu-search-border);\r\n    }\r\n  }\r\n}\r\n\r\n// 新增侧边栏\r\n@mixin slider-menu($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type==topCol {\r\n        color: map-get($map: $theme, $key: top-col);\r\n      } @else if $type==bgCol {\r\n        background: map-get($map: $theme, $key: sl-bg-col);\r\n      } @else if $type==itemCol {\r\n        color: map-get($map: $theme, $key: item-col);\r\n      } @else if $type==tooBg {\r\n        background: map-get($map: $theme, $key: toobg);\r\n      } @else if $type==tooCol {\r\n        color: map-get($map: $theme, $key: tooCol);\r\n      } @else if $type==tooAfter {\r\n        border-top-color: map-get($map: $theme, $key: toobg);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 顶部导航\r\n@mixin nav-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == bg {\r\n        background-color: map-get($map: $theme, $key: bg-color-nav);\r\n      } @else if $type == clr {\r\n        color: map-get($map: $theme, $key: text-color-nav);\r\n      } @else if $type == textactive {\r\n        color: map-get($map: $theme, $key: text-color-nav--active);\r\n      } @else if $type == active-bg {\r\n        background-color: map-get($map: $theme, $key: bg-active-active);\r\n      } @else if $type == line {\r\n        background-color: map-get($map: $theme, $key: line-color-nav);\r\n      } @else if $type == input {\r\n        background-color: map-get($map: $theme, $key: bg-color-nav-input);\r\n        border-color: map-get($map: $theme, $key: border-color-nav-input);\r\n      } @else if $type == dot {\r\n        color: map-get($map: $theme, $key: color-nav-dot);\r\n        background-color: map-get($map: $theme, $key: color-nav-dot);\r\n      } @else if $type == logo {\r\n        background-image: map-get($map: $theme, $key: color-nav-logo);\r\n      } @else if $type == logo-cut {\r\n        background-image: map-get($map: $theme, $key: color-nav-logo--cut);\r\n      } @else if $type == icon {\r\n        color: map-get($map: $theme, $key: color-nav-icon);\r\n      } @else if $type == bg-line {\r\n        background-color: map-get($map: $theme, $key: line-color);\r\n      } @else if $type == hover {\r\n        background-color: map-get($map: $theme, $key: bg-color-hover);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: text-color-nav);\r\n        background-color: map-get($map: $theme, $key: bg-color-nav);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 背景色\r\n@mixin bg-color-base($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == base {\r\n        background-color: map-get($map: $theme, $key: bg-color-base);\r\n      } @else if $type == wrap {\r\n        background-color: map-get($map: $theme, $key: bg-color-warp);\r\n      } @else if $type == light {\r\n        background-color: map-get($map: $theme, $key: bg-color-light);\r\n      } @else if $type == pop {\r\n        background-color: map-get($map: $theme, $key: bg-color-pop);\r\n      } @else if $type == pop-active {\r\n        background-color: map-get($map: $theme, $key: bg-color-pop-acitve);\r\n      } @else if $type == input {\r\n        background-color: map-get($map: $theme, $key: bg-color-input);\r\n      } @else {\r\n        background-color: map-get($map: $theme, $key: bg-color-base);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 图标色\r\n@mixin icon-color-base($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == nav {\r\n        color: map-get($map: $theme, $key: nav-icon-color);\r\n      } @else if $type == routine {\r\n        color: map-get($map: $theme, $key: routine-icon-color);\r\n      } @else if $type == disabled {\r\n        color: map-get($map: $theme, $key: disabled-icon-color);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: nav-icon-color);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 边框色\r\n@mixin border-color-base($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == base {\r\n        border-color: map-get($map: $theme, $key: border-color-base);\r\n      } @else if $type == light {\r\n        border-color: map-get($map: $theme, $key: border-color-light);\r\n      } @else if $type == lighter {\r\n        border-color: map-get($map: $theme, $key: border-color-lighter);\r\n      } @else {\r\n        border-color: map-get($map: $theme, $key: border-color-base);\r\n      }\r\n    }\r\n  }\r\n}\r\n@mixin indexSub($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type==firstCol {\r\n        color: map-get($map: $theme, $key: sub-first);\r\n      } @else if $type==nextCol {\r\n        color: map-get($map: $theme, $key: sub-next);\r\n      } @else if $type==lastCol {\r\n        color: map-get($map: $theme, $key: sub-last);\r\n      } @else if $type==lastIcon {\r\n        background: map-get($map: $theme, $key: sub-last);\r\n      } @else if $type==notAssigned {\r\n        color: map-get($map: $theme, $key: sub-nota) !important;\r\n      } @else if $type==notAssignedCale {\r\n        border-color: map-get($map: $theme, $key: sub-nota) !important;\r\n      } @else if $type==indexIcon {\r\n        background: map-get($map: $theme, $key: sub-nota) !important;\r\n      } @else if $type==active {\r\n        background: map-get($map: $theme, $key: sub-activeB);\r\n        color: map-get($map: $theme, $key: sub-activec);\r\n      } @else if $type==bgline {\r\n        background: map-get($map: $theme, $key: sub-line) !important;\r\n      } @else if $type==sub-bg {\r\n        border-color: map-get($map: $theme, $key: sub-bg);\r\n      }\r\n    }\r\n  }\r\n}\r\n// 文本色\r\n@mixin table-col($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type==bgmain {\r\n        background-color: map-get($map: $theme, $key: bgmain);\r\n      }\r\n    }\r\n  }\r\n}\r\n// 文本色\r\n@mixin text-color-base($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      // @if $type == title1 {\r\n      //   color: map-get($map: $theme, $key: text-color-1);\r\n      // } @else if $type == text1 {\r\n      //   color: map-get($map: $theme, $key: text-color-2);\r\n      // } @else {\r\n      //   color: map-get($map: $theme, $key: text-color-1);\r\n      // }\r\n      @if $type == main {\r\n        color: map-get($map: $theme, $key: text-color-base);\r\n      } @else if $type == subtitle {\r\n        color: map-get($map: $theme, $key: text-color-subtitle);\r\n      } @else if $type == routine {\r\n        color: map-get($map: $theme, $key: text-color-routine);\r\n      } @else if $type == secondary {\r\n        color: map-get($map: $theme, $key: text-color-secondary);\r\n      } @else if $type == occupy {\r\n        color: map-get($map: $theme, $key: text-color-occupy);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: text-color-base);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 首页\r\n@mixin index-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == title {\r\n        color: map-get($map: $theme, $key: title-color-index);\r\n      } @else if $type == svg {\r\n        color: map-get($map: $theme, $key: svg-color-index);\r\n      } @else if $type == card {\r\n        color: map-get($map: $theme, $key: title-color-index);\r\n        background-color: map-get($map: $theme, $key: card-color-index);\r\n      } @else if $type == cardhover {\r\n        background-color: map-get($map: $theme, $key: card-color-index--hover);\r\n      } @else if $type == borderbt {\r\n        border-bottom: 1px solid map-get($map: $theme, $key: notice-color-border);\r\n      } @else if $type == subtitle {\r\n        color: map-get($map: $theme, $key: routine-title-color);\r\n      } @else if $type == icon {\r\n        color: map-get($map: $theme, $key: nav-icon-color);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: title-color-index);\r\n        background-color: map-get($map: $theme, $key: card-color-index);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 背景色\r\n// @mixin bg-color($type) {\r\n//   @each $themename , $theme in $themes {\r\n//     [data-theme = \'#{$themename}\'] & {\r\n//       @if $type == title {\r\n//         background-color: map-get($map: $theme, $key: bg-color-light);\r\n//       }@else if $type == card {\r\n//         background-color: map-get($map: $theme, $key: bg-color-content);\r\n//       } @else {\r\n//         background-color: map-get($map: $theme, $key: bg-color-base);\r\n//       }\r\n//     }\r\n//   }\r\n// }\r\n\r\n// 忘记密码,微信修改页背景图片\r\n@mixin bg-forge-image() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background: map-get($map: $theme, $key: bg-forge-image) no-repeat top;\r\n    }\r\n  }\r\n}\r\n\r\n// 忘记密码,微信主题色开始\r\n@mixin bg-forge-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == content {\r\n        background-color: map-get($map: $theme, $key: bg-forge-content-color);\r\n      } @else if $type == tab {\r\n        background-color: map-get($map: $theme, $key: bg-forge-tab-bgcolor);\r\n      } @else if $type == tabFont {\r\n        color: map-get($map: $theme, $key: bg-forge-tab-tabFont);\r\n      } @else if $type == tabFontActive {\r\n        color: map-get($map: $theme, $key: bg-forge-tab-tabFontActive);\r\n      } @else if $type == stepsBorder {\r\n        border-bottom: 1px solid map-get($map: $theme, $key: bg-forge-tab-stepsColor);\r\n      } @else if $type == inputLabel {\r\n        color: map-get($map: $theme, $key: bg-forge-input-label);\r\n      } @else if $type == inputText {\r\n        color: map-get($map: $theme, $key: bg-forge-input-text);\r\n      } @else if $type == topBg {\r\n        // 顶部背景颜色\r\n        background-color: map-get($map: $theme, $key: bg-forge-top-bg);\r\n      } @else if $type == topLogo {\r\n        // 顶部图片\r\n        background-image: map-get($map: $theme, $key: bg-forge-top-logo);\r\n      } @else if $type == inputBorder {\r\n        border-bottom: 1px solid map-get($map: $theme, $key: bg-forge-input-border);\r\n      } @else if $type == reset {\r\n        color: map-get($map: $theme, $key: bg-forge-reset);\r\n      } @else if $type == elcarouselbg {\r\n        background-color: map-get($map: $theme, $key: el-carousel-bg);\r\n      } @else if $type == elcarouselbgHover {\r\n        background-color: map-get($map: $theme, $key: l-carousel-bg-hover);\r\n      }\r\n    }\r\n  }\r\n}\r\n// dark：表示深色的，暗色的\r\n// light：表示浅色的，淡色的。\r\n// deep：深红深紫等。\r\n// pale：非常淡的\r\n// rich：浓红色、浓金色\r\n// bright：鲜艳、鲜黄色鲜橙色\r\n// soft：柔和\r\n// pastel：泛白的、淡色的\r\n/**\r\n使用方法\r\n@include text-color-dync((白色主题, 红色主题色号,深色主题色号), 是否important默认否);\r\n@include bg-color-dync((白色主题, 红色主题色号,深色主题色号), 是否important默认否);\r\n@include border-color-dync((白色主题, 红色主题色号,深色主题色号), 是否important默认否);\r\n@include bg-color-dync($blackwhite2);\r\n@include text-color-dync((#37393D,#FFFFFF,#FFFFFF));\r\n@include border-color-dync((#37393D,#FFFFFF,#FFFFFF), true, \'bottom\');\r\n*/\r\n// 黑色开头的主题色\r\n$blackwhite2: (#37393d, #ffffff, #ffffff);\r\n$blackredblack-light: (#979da4, #f8cece, #999999);\r\n$black2white: (#37393d, #37393d, #ffffff);\r\n$black2white-light: (#979da4, #979da4, #ffffff);\r\n$black2white-rich: (#4b4d51, #37393d, #ffffff);\r\n$black3-dark: (#37393d, #37393d, #000000);\r\n$black3-light: (#979da4, #979da4, #999999);\r\n$black3-soft: (#5a6068, #5a6068, #c0c4c8);\r\n$blackredblack: (#979da4, #fadddd, #999999);\r\n$black-opacity: (rgba(102, 102, 102, 0.1), rgba(102, 102, 102, 0.1), rgba(0, 0, 0, 0.2));\r\n// 红色开头的主题色\r\n$red: (#de0b0b, #de0b0b, #de0b0b);\r\n$red3-rich: (#de4545, #de4545, #de4545);\r\n$red2white: (#e60012, #e60012, #ffffff);\r\n$redwhitered: (#de0b0b, #ffffff, #de0b0b);\r\n\r\n// 白色开头的主题色\r\n$white2black: (#ffffff, #ffffff, #2d2d2d);\r\n$white2black-light: (#e6e8ed, #e6e8ed, #4b4b4b);\r\n$white2black-pastel: (#ffffff, #ffffff, #383838);\r\n$white2black-soft: (#d2d5da, #d2d5da, #4b4b4b);\r\n$white2black-bright: (#f7ebeb, #f7ebeb, #4a4a4a);\r\n$white2black-pale: (#ffffff, #ffffff, #4a4a4a);\r\n$white2red-rich: (#f7ebeb, #f7ebeb, #513131);\r\n$white3-dark: (#cccccc, #cccccc, #262626);\r\n$whiteredblack: (#f7f8fa, #e85555, #4a4a4a);\r\n$whiteredblack-soft: (#d2d5da, #ef8585, #666666);\r\n$whiteredblack-dark: (#ffffff, #de0b0b, #2d2d2d);\r\n',"/***********************************************   new   ************************************************/\r\n\r\n/**\r\n * @title 字号\r\n */\r\n// 最小号\r\n$font-size-small-x: 10px;\r\n// 小号\r\n$font-size-small: 12px;\r\n// 中号\r\n$font-size-medium: 14px;\r\n// 中大号\r\n$font-size-medium-x: 16px;\r\n// 大号\r\n$font-size-large: 18px;\r\n// 超大号\r\n$font-size-large-x: 22px;\r\n// 其他字号-13\r\n$font-size-13: 13px;\r\n// 其他字号-20\r\n$font-size-20: 20px;\r\n\r\n\r\n//  表单\r\n// 固定宽度\r\n$item-col-width: 200px;\r\n//  左右边距\r\n$item-col-padding-rl: 10px;\r\n// 卡片内边距\r\n$card-padding: 20px;\r\n\r\n\r\n/* Color\r\n-------------------------- */\r\n/// 浅色主题\r\n$-color-theme-shalow: #FFFFFF !default;\r\n/// 黑色主题\r\n$-color-theme-dark: #2D2D2D !default;\r\n/// 品牌色\r\n$-color-brand: #E60012 !default;\r\n$-color-brand-my: #DE0B0B !default;\r\n\r\n/// 白色\r\n$-color-white: #FFFFFF !default;\r\n/// 黑色\r\n$-color-black: #000000 !default;\r\n\r\n/// 成功\r\n$-color-success: #22CE88 !default;\r\n/// 提示\r\n$-color-warning: #FAA111 !default;\r\n/// 警示\r\n$-color-danger: #FF1333 !default;\r\n/// 描述\r\n$-color-info: #909399 !default;\r\n\r\n\r\n/**\r\n * @title 常用透明度\r\n */\r\n$-percent-1: 10%;\r\n$-percent-2: 20%;\r\n$-percent-3: 30%;\r\n$-percent-4: 40%;\r\n\r\n/// 品牌色扩展\r\n$-color-brand-light-1: mix($-color-white, $-color-brand, $-percent-1) !default;\r\n$-color-brand-light-2: mix($-color-white, $-color-brand, $-percent-2) !default;\r\n$-color-brand-light-3: mix($-color-white, $-color-brand, $-percent-3) !default;\r\n$-color-brand-light-4: mix($-color-white, $-color-brand, $-percent-4) !default;\r\n\r\n$-color-brand-dark-1: mix($-color-black, $-color-brand, $-percent-1) !default;\r\n$-color-brand-dark-2: mix($-color-black, $-color-brand, $-percent-2) !default;\r\n$-color-brand-dark-3: mix($-color-black, $-color-brand, $-percent-3) !default;\r\n$-color-brand-dark-4: mix($-color-black, $-color-brand, $-percent-4) !default;\r\n\r\n$-color-theme-dark-1: mix($-color-white, $-color-theme-dark, $-percent-1) !default;\r\n\r\n/********** 文字颜色--深色主题 ******************/\r\n// 主标题文字\r\n$-color-text-dark-main: $-color-white !default;\r\n// 次标题文字\r\n$-color-text-dark-subtitle: $-color-white !default;\r\n// 常规文字\r\n$-color-text-dark-routine: #DEDEDE !default;\r\n// 次要文字\r\n$-color-text-dark-secondary: #A1A3A6 !default;\r\n// 提示文字\r\n$-color-text-dark-occupy: #B2B2B2 !default;\r\n// 禁用状态文字\r\n$-color-text-dark-disabled: #888888 !default;\r\n\r\n/********** 文字颜色--浅色主题 ******************/\r\n// 主标题文字\r\n$-color-text-shalow-main: #2B2D42!default;\r\n// 次标题文字\r\n$-color-text-shalow-subtitle: #4C4D57 !default;\r\n// 常规文字\r\n$-color-text-shalow-routine: #61666D !default;\r\n// 次要文字\r\n$-color-text-shalow-secondary: #9499A3 !default;\r\n// 提示文字\r\n$-color-text-shalow-occupy: #A1A3A6 !default;\r\n// 禁用状态文字\r\n$-color-text-shalow-disabled: #BBBBBB !default;\r\n\r\n/********** 边框颜色--深色主题 ******************/\r\n// 一级边框（按钮边框颜色）\r\n$-color-border-dark-base: #4B4B4B !default;\r\n// 二级边框（表单组件边框颜色）\r\n$-color-border-dark-light: #4B4B4B !default;\r\n// 三级边框（其他边框：表格边框颜色，卡片边框颜色）\r\n$-color-border-dark-lighter: #4B4B4B !default;\r\n\r\n/********** 边框颜色--浅色主题 ******************/\r\n// 一级边框（按钮边框颜色）\r\n$-color-border-shalow-base: #B0B3B6 !default;\r\n// 二级边框（表单组件边框颜色）\r\n$-color-border-shalow-light: #C4C8CC !default;\r\n// 三级边框（其他边框：表格边框颜色，卡片边框颜色）\r\n$-color-border-shalow-lighter: #DCDEE1 !default;\r\n// 背景为红色的边框\r\n$-color-border-shalow-bg: #EF8585 !default;\r\n// 其他边框颜色（不在规范内）\r\n$-color-border-shalow-1: #ebebeb !default;\r\n\r\n/********** 背景色--深色主题 ******************/\r\n// 文字展示背景色\r\n$-color-bg-dark-base: #1B1B1B !default;\r\n// 标题（卡片）背景色\r\n$-color-bg-dark-light: #2D2D2D !default;\r\n// 弹出框背景色（下拉选择，日期选择，确认框背景色）\r\n$-color-bg-dark-pop: #1F1F1F !default;\r\n// 弹出框激活背景色（下拉选择，日期选择，确认框选中时候的背景色）\r\n$-color-bg-dark-pop-active: #2A2A2A !default;\r\n// 表单标题背景（30%透明度）； 导航栏输入框背景底色； 其他通用组件选择激活背景底色\r\n$-color-bg-dark-title-active: #363636 !default; // 4B4B4B\r\n// $-color-bg-dark-title-active: rgb(75, 75, 75, .3) !default; // 4B4B4B\r\n// 输入框背景\r\n$-color-bg-dark-input: #4B4B4B !default;\r\n// 输入控件背景色-禁用\r\n$-color-bg-dark-input-disabled: #404040 !default;\r\n// 表格当前选中行的颜色\r\n$-color-bg-dark-current: #4B4B4B !default;\r\n// 报价模板卡片操作栏背景色\r\n$-color-bg-dark-quote: #363636 !default;\r\n// 首页的块的激活颜色\r\n$-color-bg-dark-index-block-active: #242424 !default;\r\n// 滚动条-滑动条颜色\r\n$-color-bg-dark-scrollbar-thumb: #A1A3A6 !default;\r\n// 滚动条-滑动条背景颜色\r\n$-color-bg-dark-scrollbar-bg: #1F1F1F !default;\r\n\r\n/********** 背景色--浅色主题 ******************/\r\n// 文字展示背景色\r\n$-color-bg-shalow-base: #EBEBEB !default;\r\n// 弹窗背景色\r\n$-color-bg-shalow-light: #FFFFFF !default;\r\n// 弹出框背景色（下拉选择，日期选择，确认框背景色）\r\n$-color-bg-shalow-pop: #FFFFFF !default;\r\n// 弹出框激活背景色（下拉选择，日期选择，确认框选中时候的背景色）\r\n$-color-bg-shalow-pop-active: #F2F2F2 !default;\r\n// 表单标题背景（30%透明度）； 导航栏输入框背景底色； 其他通用组件选择激活背景底色\r\n$-color-bg-shalow-title-active: #F2F2F2 !default;\r\n// 输入框背景\r\n$-color-bg-shalow-input: #F2F2F2 !default;\r\n// 输入控件背景色-禁用\r\n$-color-bg-shalow-input-disabled: #F4F4F4 !default;\r\n// 其他背景色（不在规范内）\r\n$-color-bg-shalow-light-1: #EBEBEB !default;\r\n// 当前选中行的颜色\r\n$-color-bg-shalow-current: #F2F2F2 !default;\r\n// 报价模板卡片操作栏背景色\r\n$-color-bg-shalow-quote: #F2F2F2 !default;\r\n// 首页的块的激活颜色\r\n$-color-bg-shalow-index-block-active: #F2F2F2 !default;\r\n// 滚动条-滑动条颜色\r\n$-color-bg-shadlow-scrollbar-thumb: #B2B2B2 !default;\r\n// 滚动条-滑动条背景颜色\r\n$-color-bg-shadlow-scrollbar-bg: #F2F2F2 !default;\r\n\r\n/********** 图标色--深色主题 ******************/\r\n// 品牌颜色图标\r\n$-color-icon-dark-brand: $-color-brand !default;\r\n// 侧边栏图标颜色\r\n$-color-icon-dark-nav: #C4C8CC !default;\r\n// 常规图标颜色\r\n$-color-icon-dark-routine: #B2B2B2 !default;\r\n// 禁用图标颜色\r\n$-color-icon-dark-disabled: #888888 !default;\r\n\r\n/********** 图标色--浅色主题 ******************/\r\n// 品牌颜色图标\r\n$-color-icon-shalow-brand: $-color-brand !default;\r\n// 侧边栏图标颜色\r\n$-color-icon-shalow-nav: #9499A3 !default;\r\n// 常规图标颜色\r\n$-color-icon-shalow-routine: #A1A3A6 !default;\r\n// 禁用图标颜色\r\n$-color-icon-shalow-disabled: #BBBBBB !default;\r\n\r\n// 阴影\r\n$-color-shadow-dark: rgba(209,213,223,0) !default;\r\n$-color-shadow-shalow:  rgba(209,213,223,0.5) !default;\r\n\r\n$-color-shadow-entity-dark: #4B4B4B !default;\r\n$-color-shadow-entity-shalow:  #E3E3E3 !default;\r\n$-color-shadow-entity-shalow-brand:  #EF8585 !default;\r\n\r\n/* Font\r\n------------*/\r\n$-font-path: 'fonts' !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-extra-large: 20px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-large: 18px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-medium: 16px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-base: 14px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-small: 13px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-extra-small: 12px !default;\r\n/// fontSize|1|Font Size|0\r\n$-font-size-extra-small-r: 10px !default;\r\n/// fontWeight|1|Font Weight|1\r\n$-font-weight-primary: 500 !default;\r\n/// fontWeight|1|Font Weight|1\r\n$-font-weight-secondary: 100 !default;\r\n/// fontLineHeight|1|Line Height|2\r\n$-font-line-height-primary: 24px !default;\r\n/// fontLineHeight|1|Line Height|2\r\n$-font-line-height-secondary: 16px !default;\r\n$-font-color-disabled-base: #bbb !default;\r\n\r\n/* z-index\r\n-------------------------- */\r\n$--index-normal: 1 !default;\r\n$--index-top: 1000 !default;\r\n$--index-popper: 2000 !default;\r\n\r\n/* 通用圆角 */\r\n$r