alow-pop,\r\n  // 报价选中小三角\r\n  border-color-arrow: $-color-text-shalow-secondary,\r\n  // 报价新增加号\r\n  border-color-plus: $-color-icon-shalow-nav,\r\n\r\n  border-color-my: #D2D5DA,\r\n  // 浮动的边框颜色\r\n  border-color-my-main: #EDEDED,\r\n  border-color-my-theme: #EF8585,\r\n  border-color-my-theme-hover: #ffffff,\r\n/********** icon色--浅色主题 ******************/\r\n  // 品牌色icon\r\n  brand-icon-color: $-color-icon-shalow-brand,\r\n  // 导航色icon\r\n  nav-icon-color: $-color-icon-shalow-nav,\r\n  // 常规icon颜色\r\n  routine-icon-color: $-color-icon-shalow-routine,\r\n  // 禁用icon颜色\r\n  disabled-icon-color: $-color-icon-shalow-disabled,\r\n\r\n/********** 背景色--浅色色主题 ******************/\r\n  // 品牌色背景色\r\n  bg-color-brand: $-color-brand,\r\n  // 主题色\r\n  bg-color-main: $-color-theme-shalow,\r\n  // hover\r\n  bg-color-hover: $-bg-color-hover-brand,\r\n  bg-color-my: #F7F8FA,\r\n  bg-color-my-hover: #FFFFFF,\r\n  bg-color-my-theme: $-color-brand-my,\r\n  // 全局大背景颜色\r\n  bg-color-base: $-color-bg-shalow-base,\r\n  // 标题（表单、卡片）背景色\r\n  bg-color-light: $-color-bg-shalow-light,\r\n  // 弹出框背景色（下拉选择，日期选择，确认框背景色）\r\n  bg-color-pop: $-color-bg-shalow-pop,\r\n  // 弹出框激活背景色（下拉选择，日期选择，确认框选中时候的背景色）\r\n  bg-color-pop-active: $-color-bg-shalow-pop-active,\r\n  // 表单标题背景（30%透明度）； 导航栏输入框背景底色； 其他通用组件选择激活背景底色\r\n  bg-color-title-active: $-color-bg-shalow-title-active,\r\n  // 输入控件背景色（实心）\r\n  bg-color-input-solid: $-color-border-shalow-light,\r\n  // 输入控件背景色\r\n  bg-color-input: $-color-bg-shalow-input,\r\n  // 输入控件 下啦空间的禁用背景色\r\n  bg-color-input-disabled: $-color-bg-shalow-input-disabled,\r\n  // 表格当前选中行的颜色\r\n  bg-color-current: $-color-bg-shalow-current,\r\n  // 次标题对应的线条背景色 \r\n  bg-color-subtitle: $-color-text-shalow-subtitle,\r\n  // 报价模板卡片操作栏背景色\r\n  bg-color-quote: $-color-bg-shalow-quote,\r\n  // 报价模板卡片状态背景\r\n  bg-color-tag-bg: $-color-icon-shalow-routine,\r\n  // 首页的块的激活颜色\r\n  bg-color-index-block-active: $-color-bg-shalow-index-block-active,\r\n  // 滚动条-滑动条背景颜色\r\n  bg-color-scrollbar-thumb: $-color-bg-shadlow-scrollbar-thumb,\r\n  // 滚动条-滑动条颜色\r\n  bg-color-scrollbar-bg: $-color-bg-shadlow-scrollbar-bg,\r\n\r\n  // 阴影\r\n  shadow-color: $-color-shadow-shalow,\r\n  shadow-color-entity: $-color-shadow-entity-shalow,\r\n  \r\n  // loading\r\n  img-loading: url('~@assets/images/loading4.gif'),\r\n);\r\n\r\n// 深色模式\r\n$black-theme:(\r\n  \r\n/********** 文字颜色--深色主题 ******************/\r\n  // 品牌色文字颜色\r\n  text-color-brand: $-color-brand,\r\n  text-color-brand-my: $-color-brand-my,\r\n  // 主标题文字颜色 （主题色）\r\n  text-color-main: $-color-text-dark-main,\r\n  // 次标题文字\r\n  text-color-subtitle: $-color-text-dark-subtitle,\r\n  // 常规文字\r\n  text-color-routine: $-color-text-dark-routine,\r\n  // 次要文字\r\n  text-color-secondary: $-color-text-dark-secondary,\r\n  // 提示文字\r\n  text-color-occupy: $-color-text-dark-occupy,\r\n  // 提示文字\r\n  text-color-disabled: $-color-text-dark-disabled,\r\n\r\n  text-color-my: #FFFFFF,\r\n  text-color-my-icon: #979DA4,\r\n  text-color-my-sub: rgba(255, 255, 255, 0.5),\r\n  text-color-my-theme: #ffffff,\r\n  text-color-my-theme-main: #ffffff,\r\n  text-color-my-theme-sub: rgb(255 255 255 / 80%),\r\n/********** 边框颜色--深色主题 ******************/\r\n  // 品牌色边框\r\n  border-color-brand: $-color-brand,\r\n  // 主题色边框\r\n  border-color-main: $-color-text-dark-main,\r\n  // 一级边框（按钮边框）\r\n  border-color-base: $-color-border-dark-base,\r\n  // 二级边框（form表单元素边框）\r\n  border-color-light: $-color-border-dark-light,\r\n  // 三级边框（其他边框，除按钮和form都用这个）\r\n  border-color-lighter: $-color-border-dark-lighter,\r\n  // 弹出框边框颜色（跟弹出框背景色一样以展示无边框的效果）\r\n  border-color-pop: $-color-bg-dark-pop,\r\n  // 报价选中小三角\r\n  border-color-arrow: $-color-text-dark-secondary,\r\n  // 报价新增加号\r\n  border-color-plus: $-color-border-shalow-light,\r\n\r\n  border-color-my: #4B4B4B,\r\n  // 浮动的边框颜色\r\n  border-color-my-main: #4B4B4B,\r\n  border-color-my-theme: #4B4B4B,\r\n  border-color-my-theme-hover: #ffffff,\r\n/********** icon颜色--深色主题 ******************/\r\n  // 品牌色icon\r\n  brand-icon-color: $-color-icon-dark-brand,\r\n  // 导航色icon\r\n  nav-icon-color: $-color-icon-dark-nav,\r\n  // 常规icon颜色\r\n  routine-icon-color: $-color-icon-dark-routine,\r\n  // 禁用icon颜色\r\n  disabled-icon-color: $-color-icon-dark-disabled,\r\n\r\n/********** 背景色--深色主题 ******************/\r\n  // 品牌背色背景色\r\n  bg-color-brand: $-color-brand,\r\n  // 主题色\r\n  bg-color-main: $-color-theme-dark,\r\n  // hover\r\n  bg-color-hover: $-bg-color-hover-dark,\r\n  bg-color-my: #383838,\r\n  bg-color-my-hover: #2D2D2D,\r\n  bg-color-my-theme: #2D2D2D,\r\n  // 全局大背景颜色\r\n  bg-color-base: $-color-bg-dark-base,\r\n  // 标题（卡片）背景色\r\n  bg-color-light: $-color-bg-dark-light,\r\n  // 弹出框背景色（下拉选择，日期选择，确认框背景色）\r\n  bg-color-pop: $-color-bg-dark-pop,\r\n  // 弹出框激活背景色（下拉选择，日期选择，确认框选中时候的背景色）\r\n  bg-color-pop-active: $-color-bg-dark-pop-active,\r\n  // 表单标题背景（30%透明度）； 导航栏输入框背景底色； 其他通用组件选择激活背景底色\r\n  bg-color-title-active: $-color-bg-dark-title-active,\r\n  // 输入控件背景色（实心）\r\n  bg-color-input-solid: $-color-bg-dark-input,\r\n  // 输入控件背景色（空心）\r\n  bg-color-input: transparent,\r\n  // 输入控件 下啦空间的禁用背景色\r\n  bg-color-input-disabled: $-color-bg-dark-input-disabled,\r\n  // 表格当前选中行的颜色\r\n  bg-color-current: $-color-bg-dark-current,\r\n  // 次标题对应的线条背景色 #4C4D57 - #FFFFFF\r\n  bg-color-subtitle: $-color-white,\r\n  // 报价模板卡片操作栏背景色\r\n  bg-color-quote: $-color-bg-dark-quote,\r\n  // 报价模板卡片状态背景\r\n  bg-color-tag-bg: $-color-icon-dark-routine,\r\n  // 首页的块的激活颜色\r\n  bg-color-index-block-active: $-color-bg-dark-index-block-active,\r\n  // 滚动条-滑动条背景颜色\r\n  bg-color-scrollbar-thumb: $-color-bg-dark-scrollbar-thumb,\r\n  // 滚动条-滑动条颜色\r\n  bg-color-scrollbar-bg: $-color-bg-dark-scrollbar-bg,\r\n\r\n  // 阴影\r\n  shadow-color: $-color-shadow-dark,\r\n  shadow-color-entity: $-color-shadow-entity-dark,\r\n\r\n  // loading\r\n  img-loading: url('~@assets/images/loading3.gif'),\r\n);\r\n\r\n//定义映射集合\r\n$component-themes: (\r\n  default-theme: $default-theme,    // 白色\r\n  green-theme: $green-theme,        // 红色\r\n  black-theme: $black-theme         // 暗色\r\n);\r\n\r\n /* 文字颜色宏  $type， 默认常规颜色 routine */\r\n// brand      品牌色文字\r\n// main       主标题文字\r\n// subtitle   次标题文字\r\n// routine    常规文字\r\n// secondary  次要文字\r\n// occupy     提示文字\r\n// disabled   禁用状态文字\r\n@mixin text-color($type:'routine'){\r\n  @each $themename , $theme in $component-themes {\r\n    [data-theme = '#{$themename}'] & {\r\n      color: map-get($map: $theme, $key: 'text-color-#{$type}');\r\n    }\r\n  }\r\n}\r\n@mixin text-color-important($type:'routine'){\r\n  @each $themename , $theme in $component-themes {\r\n    [data-theme = '#{$themename}'] & {\r\n      color: map-get($map: $theme, $key: 'text-color-#{$type}') !important;\r\n    }\r\n  }\r\n}\r\n@mixin text-color-dync($colors: (red, green, blue), $important: false){\r\n  @if $important {\r\n    [data-theme = 'default-theme'] & {\r\n      color: nth($colors, 1) !important;\r\n    }\r\n    [data-theme = 'green-theme'] & {\r\n      color: nth($colors, 2) !important;\r\n    }\r\n    [data-theme = 'black-theme'] & {\r\n      color: nth($colors, 3) !important;\r\n    }\r\n  } @else {\r\n    [data-theme = 'default-theme'] & {\r\n      color: nth($colors, 1);\r\n    }\r\n    [data-theme = 'green-theme'] & {\r\n      color: nth($colors, 2);\r\n    }\r\n    [data-theme = 'black-theme'] & {\r\n      color: nth($colors, 3);\r\n    }\r\n  }\r\n}\r\n\r\n/* 边框颜色宏  $type ， 默认三级颜色 lighter */\r\n// brand      品牌色边框\r\n// main       主题色边框\r\n// base       一级边框\r\n// light      二级边框\r\n// lighter    三级边框\r\n// pop        提示框\r\n// @params $pos 位置 top bottom right left\r\n@mixin border-color($type:'lighter', $pos: ''){\r\n  @each $themename , $theme in $component-themes {\r\n    [data-theme = '#{$themename}'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: map-get($map: $theme, $key: 'border-color-#{$type}');\r\n      } @else {\r\n        border-color: map-get($map: $theme, $key: 'border-color-#{$type}');\r\n      }\r\n    }\r\n  }\r\n}\r\n@mixin border-color-important($type:'lighter', $pos: ''){\r\n  @each $themename , $theme in $component-themes {\r\n    [data-theme = '#{$themename}'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: map-get($map: $theme, $key: 'border-color-#{$type}') !important;\r\n      } @else {\r\n        border-color: map-get($map: $theme, $key: 'border-color-#{$type}') !important;\r\n      }\r\n    }\r\n  }\r\n}\r\n@mixin border-color-dync($colors: (red, green, blue), $important: false, $pos: ''){\r\n  @if $important {\r\n    [data-theme = 'default-theme'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: nth($colors, 1) !important;\r\n      } @else {\r\n        border-color: nth($colors, 1) !important;\r\n      }\r\n    }\r\n    [data-theme = 'green-theme'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: nth($colors, 2) !important;\r\n      } @else {\r\n        border-color: nth($colors, 2) !important;\r\n      }\r\n    }\r\n    [data-theme = 'black-theme'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: nth($colors, 3) !important;\r\n      } @else {\r\n        border-color: nth($colors, 3) !important;\r\n      }\r\n    }\r\n  } @else {\r\n    [data-theme = 'default-theme'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: nth($colors, 1);\r\n      } @else {\r\n        border-color: nth($colors, 1);\r\n      }\r\n    }\r\n    [data-theme = 'green-theme'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: nth($colors, 2);\r\n      } @else {\r\n        border-color: nth($colors, 2);\r\n      }\r\n    }\r\n    [data-theme = 'black-theme'] & {\r\n      @if $pos != '' {\r\n        #{'border-' + $pos + '-color'}: nth($colors, 3);\r\n      } @else {\r\n        border-color: nth($colors, 3);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n/* 背景颜色宏  $type，默认文字展示背景颜色 text */\r\n// brand        品牌背色背景色\r\n// main         主题色背景\r\n// base         文字展示背景色\r\n// brand