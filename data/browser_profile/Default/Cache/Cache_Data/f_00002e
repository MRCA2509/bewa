t: $-color-bg-dark-input,\r\n  border-color-nav-input: $-color-bg-dark-input,\r\n  color-nav-dot: $-color-brand,\r\n  color-nav-logo: url("~@/assets/images/logo-jitu.png"),\r\n  color-nav-logo--cut: url("~@/assets/images/logo-jitu-cut.png"),\r\n  color-nav-icon: $-color-icon-dark-nav,\r\n  line-color: transparent,\r\n\r\n  // index\r\n  title-color-index: $-color-white,\r\n  svg-color-index: $-color-text-dark-subtitle,\r\n  card-color-index: $-color-bg-dark-light,\r\n  card-color-index--hover: $-color-theme-dark-1,\r\n  notice-color-border: $-color-border-dark-base,\r\n\r\n  // text\r\n  main-title-color: $-color-text-dark-main,\r\n  sub-title-color: $-color-text-dark-subtitle,\r\n  routine-title-color: $-color-text-dark-routine,\r\n  secondary-title-color: $-color-text-dark-secondary,\r\n  occupy-title-color: $-color-text-dark-occupy,\r\n\r\n  // icon\r\n  nav-icon-color: $-color-icon-dark-nav,\r\n  routine-icon-color: $-color-icon-dark-routine,\r\n  disabled-icon-color: $-color-icon-dark-disabled,\r\n\r\n  // border\r\n  border-color: $-color-border-dark-base,\r\n\r\n  // text\r\n  // 白色\r\n  text-color-1: $-color-white,\r\n  text-color-2: $-color-white,\r\n\r\n  // 忘记密码开始\r\n  bg-forge-image: url("~@/assets/images/bg/forget_bg_black.jpg"),\r\n  bg-forge-color: $-color-bg-dark-light,\r\n  // 菜单搜索框背景色\r\n  menu-search-bg: $-color-bg-dark-input,\r\n  menu-search-color: $-color-text-dark-routine,\r\n  menu-search-border: none,\r\n  bg-forge-content-color: $-color-bg-dark-light,\r\n  bg-forge-tab-bgcolor: $-color-border-dark-base,\r\n  bg-forge-tab-tabFont: $-color-text-dark-occupy,\r\n  bg-forge-tab-tabFontActive: $c-nc-1,\r\n  bg-forge-tab-stepsColor: $-color-bg-dark-input,\r\n  bg-forge-input-label: $-color-text-dark-subtitle,\r\n  bg-forge-input-text: $-color-white,\r\n  bg-forge-top-bg: $-color-bg-dark-light,\r\n  bg-forge-top-logo: url("~@/assets/images/logo-jitu.png"),\r\n  bg-forge-input-border: $-color-border-dark-base,\r\n  bg-forge-reset: $-color-white,\r\n  // 忘记密码结束\r\n  // tags\r\n  bg-color-tags: $-color-bg-dark-light,\r\n  // upload\r\n  upload-border-color: $-color-border-dark-base,\r\n  upload-border-type: solid,\r\n  upload-add-bg: $-color-bg-dark-input,\r\n  upload-right-hover: $-color-bg-dark-base,\r\n  upload-right-close-bg: $-color-bg-dark-base,\r\n  upload-img-fileBg: $-color-border-shalow-base,\r\n  upload-rightBg: $-color-white,\r\n  // upload\r\n  // 消息提示\r\n  el-alert-bg: $-color-bg-dark-pop,\r\n  el-carousel-bg: rgba(255, 255, 255, 0.2),\r\n  el-carousel-bg-hover: rgba(255, 255, 255, 0.4),\r\n  form-bottom-bg: none,\r\n  // 消息提示\r\n  //  首页菜单\r\n  sub-first: $c-nc-1,\r\n  sub-next: $-color-text-dark-routine,\r\n  sub-activeB: $-color-bg-dark-input-disabled,\r\n  sub-activec: $-color-text-dark-disabled,\r\n  sub-nota: #4e4e4e,\r\n  sub-line: #4b4b4b,\r\n  sub-bg: #dedede,\r\n  sub-last: #a1a3a6,\r\n  collect-title: #b2b2b2,\r\n  collect-item: #ffffff,\r\n  collect-icon: #dedede,\r\n  menu-border-col: #4a4a4a,\r\n  menu-hide-col: #999999,\r\n  menu-menu-col: #ffffff,\r\n  menu-file-col: #ffffff,\r\n);\r\n\r\n//定义映射集合\r\n$themes: (\r\n  default-theme: $default-theme,\r\n  green-theme: $green-theme,\r\n  // blue-theme: $blue-theme,\r\n  black-theme: $black-theme,\r\n);\r\n$asideWidth: $side-bar-first-width + $side-bar-second-width; // 侧边栏宽度\r\n$topHeight: 48px; //顶栏高度\r\n// $mini-sidebar:112px; //收缩后的菜单\r\n$mini-sidebar: $side-bar-first-width; //收缩后的菜单\r\n$submenu-height: 42px; // submenu 行高\r\n$menu-height: 42px; // 子菜单高度\r\n// 自定义滚动条\r\n@mixin scrollBarStyle() {\r\n  &::-webkit-scrollbar {\r\n    width: 7px;\r\n    height: 7px;\r\n  }\r\n  &::-webkit-scrollbar-thumb {\r\n    border-radius: 10px;\r\n    -webkit-box-shalow: inset 0 0 5px #9b9ba3;\r\n    background: rgba(152, 155, 163, 0.5);\r\n  }\r\n}\r\n\r\n@mixin theme-menu-indexCol($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == col {\r\n        border-color: map-get($theme, menu-border-col);\r\n        // color: map-get($map: $theme, $key: sub-first);\r\n      } @else if $type == hidecol {\r\n        color: map-get($theme, menu-hide-col);\r\n      } @else if $type == menu {\r\n        color: map-get($theme, menu-menu-col);\r\n      } @else if $type == file {\r\n        color: map-get($theme, menu-file-col);\r\n      }\r\n    }\r\n  }\r\n}\r\n// 主题色\r\n@mixin base-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == clr {\r\n        color: map-get($map: $theme, $key: color-main);\r\n      } @else if $type == bg {\r\n        background-color: map-get($map: $theme, $key: color-main);\r\n      } @else {\r\n        background-color: map-get($map: $theme, $key: color-main);\r\n        color: map-get($map: $theme, $key: color-main);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 主题色-new\r\n@mixin base-color-set($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == main {\r\n        color: map-get($map: $theme, $key: text-color-base);\r\n      } @else if $type == subtitle {\r\n        color: map-get($map: $theme, $key: text-color-subtitle);\r\n      } @else if $type == routine {\r\n        color: map-get($map: $theme, $key: text-color-routine) !important;\r\n      } @else if $type == secondary {\r\n        color: map-get($map: $theme, $key: text-color-secondary);\r\n      } @else if $type == occupy {\r\n        color: map-get($map: $theme, $key: text-color-occupy);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 获取主题边框\r\n@mixin base-border() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      border-color: map-get($map: $theme, $key: border-color);\r\n      //  阴影颜色无法单独替换，只能隐藏\r\n      box-shadow: none;\r\n    }\r\n  }\r\n}\r\n// 获取主题下边框\r\n@mixin base-bottom-border() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      border-bottom-color: map-get($map: $theme, $key: border-color);\r\n    }\r\n  }\r\n}\r\n\r\n// 主题色透明背景\r\n@mixin theme-hover() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background-color: map-get($map: $theme, $key: light-btn-bg);\r\n    }\r\n  }\r\n}\r\n\r\n// 主题色透明背景\r\n@mixin theme-hover-sub() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background-color: map-get($map: $theme, $key: light-btn-bg-hover);\r\n      // border-bottom: 1px solid map-get($map: $theme, $key: light-btn-text );\r\n      // border-top: 1px solid map-get($map: $theme, $key: light-btn-text );\r\n    }\r\n  }\r\n}\r\n\r\n// 主题border\r\n@mixin base-border-color() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      border: 1px solid map-get($map: $theme, $key: border-color);\r\n      //  阴影颜色无法单独替换，只能隐藏\r\n      box-shadow: none;\r\n    }\r\n  }\r\n}\r\n\r\n// 进入系统的loading\r\n@mixin base-app-loading() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      background: map-get($map: $theme, $key: app-loading);\r\n    }\r\n  }\r\n}\r\n\r\n/********  New\r\n-----------------------*/\r\n// 侧边菜单栏\r\n@mixin sider-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == textbase {\r\n        color: map-get($map: $theme, $key: text-color-sider);\r\n      } @else if $type == textactive {\r\n        color: map-get($map: $theme, $key: text-color-sider--active);\r\n      } @else if $type == bg-active {\r\n        background-color: map-get($map: $theme, $key: bg-active-color);\r\n      } @else if $type == bg-hover {\r\n        background-color: map-get($map: $theme, $key: bg-sider-hover-color);\r\n      } @else if $type == bd-line {\r\n        border-right-color: map-get($map: $theme, $key: bg-sider-line-color);\r\n      } @else if $type == bd-line-arrow {\r\n        border-color: map-get($map: $theme, $key: bg-sider-line-color);\r\n      } @else if $type == text-2-active {\r\n        color: $-color-brand;\r\n      } @else if $type == logo {\r\n        background-image: map-get($map: $theme, $key: color-nav-logo);\r\n      } @else if $type == logo-cut {\r\n        background-image: map-get($map: $theme, $key: color-nav-logo--cut);\r\n      } @else if $type == bg {\r\n        background-color: map-get($map: $theme, $key: bg-color-sider);\r\n      } @else if $type == logobox-line {\r\n        background-color: map-get($map: $theme, $key: bg-sider-boxline-color);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: text-color-brand);\r\n        background-color: map-get($map: $theme, $key: bg-color-sider-row);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 侧边菜单栏\r\n@mixin sider-color-search() {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      color: map-get($map: $theme, $key: menu-search-color);\r\n      background-color: map-get($map: $theme, $key: menu-search-bg);\r\n      border: map-get($map: $theme, $key: menu-search-border);\r\n    }\r\n  }\r\n}\r\n\r\n// 新增侧边栏\r\n@mixin slider-menu($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type==topCol {\r\n        color: map-get($map: $theme, $key: top-col);\r\n      } @else if $type==bgCol {\r\n        background: map-get($map: $theme, $key: sl-bg-col);\r\n      } @else if $type==itemCol {\r\n        color: map-get($map: $theme, $key: item-col);\r\n      } @else if $type==tooBg {\r\n        background: map-get($map: $theme, $key: toobg);\r\n      } @else if $type==tooCol {\r\n        color: map-get($map: $theme, $key: tooCol);\r\n      } @else if $type==tooAfter {\r\n        border-top-color: map-get($map: $theme, $key: toobg);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 顶部导航\r\n@mixin nav-color($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == bg {\r\n 