nd-color: map-get($map: $theme, $key: bg-color-light);\r\n      } @else if $type == pop {\r\n        background-color: map-get($map: $theme, $key: bg-color-pop);\r\n      } @else if $type == pop-active {\r\n        background-color: map-get($map: $theme, $key: bg-color-pop-acitve);\r\n      } @else if $type == input {\r\n        background-color: map-get($map: $theme, $key: bg-color-input);\r\n      } @else {\r\n        background-color: map-get($map: $theme, $key: bg-color-base);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 图标色\r\n@mixin icon-color-base($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == nav {\r\n        color: map-get($map: $theme, $key: nav-icon-color);\r\n      } @else if $type == routine {\r\n        color: map-get($map: $theme, $key: routine-icon-color);\r\n      } @else if $type == disabled {\r\n        color: map-get($map: $theme, $key: disabled-icon-color);\r\n      } @else {\r\n        color: map-get($map: $theme, $key: nav-icon-color);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 边框色\r\n@mixin border-color-base($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type == base {\r\n        border-color: map-get($map: $theme, $key: border-color-base);\r\n      } @else if $type == light {\r\n        border-color: map-get($map: $theme, $key: border-color-light);\r\n      } @else if $type == lighter {\r\n        border-color: map-get($map: $theme, $key: border-color-lighter);\r\n      } @else {\r\n        border-color: map-get($map: $theme, $key: border-color-base);\r\n      }\r\n    }\r\n  }\r\n}\r\n@mixin indexSub($type) {\r\n  @each $themename, $theme in $themes {\r\n    [data-theme="#{$themename}"] & {\r\n      @if $type==firstCol {\r\n        color: map-get($map: $theme, $key: sub-first);\r\n      } @else if $type==nextCol {\r\n        color: map-get($map: $theme, $key: sub-next);\r\n      } @else if $type==lastCol {\r\n        col